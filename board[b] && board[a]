board[c]) {
      return {
        winner: board[a] as 'X' | 'O',
        isDraw: false,
        winningLine: line,
      };
    }
  }

  const isDraw = board.every((cell) => cell !== null);
  return {
    winner: null,
    isDraw,
    winningLine: null,
  };
}

export function getNextPlayer(currentPlayer: string): string {
  return currentPlayer === 'X' ? 'O' : 'X';
}

export function makeMove(
  board: BoardState,
  index: number,
  player: string
): BoardState | null {
  if (index < 0 || index > 8 || board[index] !== null) {
    return null;
  }
  const newBoard = [...board];
  newBoard[index] = player as CellValue;
  return newBoard;
}

export function generateShareText(
  playerXName: string,
  playerOName: string,
  result: GameResult
): string {
  let resultLine: string;
  if (result.isDraw) {
    resultLine = "It's a draw! 🤝";
  } else if (result.winner === 'X') {
    resultLine = `${playerXName} (✕) wins! 🎉`;
  } else {
    resultLine = `${playerOName} (○) wins! 🎉`;
  }

  return [
    '🎮 Tic Tac Toe Result',
    '━━━━━━━━━━━━━━━━━━━',
    `✕ ${playerXName}  vs  ○ ${playerOName}`,
    '',
    resultLine,
    '',
    '#TicTacToe #Gaming',
  ].join('\n');
}
