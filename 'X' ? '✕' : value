<file path="src/components/GameHistory.tsx">
'use client';

import { useState, useEffect } from 'react';

interface GameRecord {
  id: number;
  playerX: { id: number; username: string };
  playerO: { id: number; username: string };
  winner: { id: number; username: string } | null;
  status: string;
  moves: { player: string; index: number }[];
  createdAt: string;
  completedAt: string;
}

interface GameHistoryProps {
  playerId: number;
}

export default function GameHistory({ playerId }: GameHistoryProps) {
  const [games, setGames] = useState<GameRecord[]>([]);
  const [loading, setLoading] = useState(true);

  useEffect(() => {
    setLoading(true);
    fetch(`/api/games?playerId=${playerId}&limit=50`)
      .then((r) => r.json())
      .then((data) => {
        if (data.games && Array.isArray(data.games)) {
          setGames(data.games);
        }
        setLoading(false);
      })
      .catch(() => setLoading(false));
  }, [playerId]);

  if (loading) {
    return (
      <div className="text-center mt-4">
        <div className="spinner" />
      </div>
    );
  }

  if (games.length === 0) {
    return (
      <div className="empty-state">
        <div className="empty-icon">📋</div>
        <p>No games played yet.</p>
      </div>
    );
  }

  return (
    <div className="flex flex-col gap-4">
      <h3 style={{ fontWeight: 700, fontSize: '1.2rem' }}>📋 Game History</h3>
      {games.map((game) => {
        let resultBadge: string;
        let resultClass: string;

        if (game.status === 'draw') {
          resultBadge = 'Draw';
          resultClass = 'badge-draw';
        } else if (game.winner && game.winner.id === playerId) {
          resultBadge = 'Win';
          resultClass = 'badge-win';
        } else {
          resultBadge = 'Loss';
          resultClass = 'badge-loss';
        }

        // Reconstruct mini board
        const miniBoard: (string | null)[] = Array(9).fill(null);
        game.moves.forEach((m) => {
          miniBoard[m.index] = m.player;
        });

        return (
          <div key={game.id} className="game-card">
            <div className="mini-board">
              {miniBoard.map((cell, i) => (
                <div
                  key={i}
                  className={`mini-cell ${cell